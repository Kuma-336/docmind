# ============================================================
# DocMind 环境变量配置示例
# 使用方法：cp .env.example .env，然后填入真实值
# 警告：.env 文件含有密钥，绝对不要提交到 Git 仓库
# ============================================================

# ---------- 应用基础 ----------
APP_NAME=DocMind
APP_VERSION=0.1.0
DEBUG=false

# ---------- LLM（必填）----------
# OpenAI 兼容接口的 API Key（DeepSeek / OpenAI / 其他）
OPENAI_API_KEY=your_openai_api_key_here

# 自定义 API Base URL（使用 DeepSeek 等兼容接口时填写；使用官方 OpenAI 留空）
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 使用的模型名称
OPENAI_MODEL=deepseek-chat

# ---------- Embedding 模型 ----------
# HuggingFace 模型 ID（本地推理，不消耗 API 额度）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ---------- 网络搜索（可选）----------
# 填写后启用 Tavily 联网搜索；留空则降级为 DuckDuckGo（无需 Key）
TAVILY_API_KEY=your_tavily_api_key_here

# ---------- 数据存储路径 ----------
# 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma

# 上传文件存储目录
UPLOAD_DIR=./data/uploads

# 会话历史 SQLite 数据库路径
SESSION_DB_PATH=./data/sessions.db

# ---------- RAG 参数 ----------
# 每次检索返回的最大文档块数
RETRIEVER_TOP_K=5

# 相关度分数阈值（0~1，低于此值的结果被过滤；越大越严格）
RETRIEVER_SCORE_THRESHOLD=0.5

# 文档分块大小（字符数）
CHUNK_SIZE=1000

# 分块重叠字符数
CHUNK_OVERLAP=200

# ---------- 文档上传限制 ----------
# 单文件大小上限（MB）
MAX_UPLOAD_SIZE_MB=20

# ---------- 会话历史 ----------
# Prompt 中注入的历史对话轮数上限
SESSION_HISTORY_LIMIT=3
